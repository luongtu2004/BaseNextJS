# PostgreSQL async (SQLAlchemy 2 + psycopg3). Có thể đổi sang postgresql+asyncpg nếu cài được asyncpg.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/sandichvu

# JWT (đổi secret production; tối thiểu 32 ký tự ngẫu nhiên)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# OTP (dev: có thể log ra console; production: nối SMS gateway)
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# SMS / Zalo / Twilio... (tùy nhà cung cấp)
# SMS_API_KEY=
# SMS_SENDER_ID=

# Redis (tùy chọn — OTP session + refresh token blacklist)
# REDIS_URL=redis://localhost:6379/0

# App
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# VNPAY Sandbox Configs
VNPAY_TMN_CODE=TESTCODE
VNPAY_HASH_SECRET=0123456789ABCDEF0123456789ABCDEF
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8000/api/v1/internal/payments/vnpay/return

# MoMo Sandbox Configs
MOMO_PARTNER_CODE=MOMO_TEST
MOMO_ACCESS_KEY=MOMO_ACCESS
MOMO_SECRET_KEY=MOMO_SECRET
MOMO_PAYMENT_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:8000/api/v1/internal/payments/momo/return
MOMO_NOTIFY_URL=http://localhost:8000/api/v1/internal/payments/momo/callback

# ZaloPay Sandbox Configs
ZALOPAY_APP_ID=2553
ZALOPAY_KEY1=ZALOPAY_TEST_KEY1
ZALOPAY_KEY2=ZALOPAY_TEST_KEY2
ZALOPAY_PAYMENT_URL=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_CALLBACK_URL=http://localhost:8000/api/v1/internal/payments/zalopay/callback
